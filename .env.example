# Mapbox GL token (publishable, client-side). Get one at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# OpenRouter API key (server-side). Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ElevenLabs (server-side): TTS (`/api/voice`) + realtime Scribe tokens (`/api/scribe-token`).
# The key needs both Text-to-Speech and Speech-to-Text permissions enabled.
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional per-persona voice overrides (defaults to built-in library voices)
ELEVENLABS_VOICE_LADYBIRD=
ELEVENLABS_VOICE_WITCH=
# Lucy (Materialists): default Alexandra — young, upbeat, chatty. Alternates to try:
#   Cassidy (56AoDkrOh6qfVPDXZ7Pt) — energetic, entertainment
#   Freya (jsCqWAovK2LkecY7zXl4) — young, brisk, slightly hyped
ELEVENLABS_VOICE_MATERIALIST=

# Valence Pulse (server-side only): vocal emotion analysis for mic turns.
# Get a key from Valence AI — never expose to the browser.
VALENCE_API_KEY=
